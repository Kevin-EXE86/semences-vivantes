---
// ressources.astro
import BaseLayout from '../layouts/BaseLayout.astro';

const ressources = [
  {
    categorie: "🌱 Semences bio",
    items: [
      {
        nom: "Agrieuro — Matériel de jardin bio",
        desc: "Le site référence pour l'outillage maraîcher et les accessoires de jardinage biologique. Large choix, prix compétitifs.",
        lien: "https://www.agrieuro.fr",
        badge: "Affilié — 15% de commission",
        affilie: true,
      },
      {
        nom: "La Semence Bio",
        desc: "Semences 100% bio et reproductibles, certifiées Ecocert. Idéales pour un potager autonome et durable.",
        lien: "https://www.lasemencebio.com",
        badge: "Recommandé",
        affilie: false,
      },
    ],
  },
  {
    categorie: "🔧 Outils & accessoires",
    items: [
      {
        nom: "Amazon — Jardinage bio",
        desc: "Notre sélection d'outils, mini-serres, pots biodégradables et accessoires de semis disponibles sur Amazon.",
        lien: "https://amzn.to/49BrAgB",
        badge: "Affilié — jusqu'à 10%",
        affilie: true,
      },
      {
        nom: "ManoMano — Jardinage",
        desc: "Grande sélection de matériel de jardinage, souvent moins cher qu'en jardinerie. Livraison rapide.",
        lien: "https://www.manomano.fr",
        badge: "Affilié — jusqu'à 7%",
        affilie: true,
      },
    ],
  },
  {
    categorie: "📚 Livres conseillés",
    items: [
      {
        nom: "\"Apprendre à faire ses graines et semences: Guide pratique illustré\"",
        desc: "Le livre de référence sur la conservation et la multiplication des semences anciennes. Indispensable.",
        lien: "https://www.amazon.fr/Apprendre-faire-ses-graines-semences/dp/2867397677/ref=sr_1_4?__mk_fr_FR=%C3%85M%C3%85%C5%BD%C3%95%C3%91&crid=1A6WRT4F7QKBF&dib=eyJ2IjoiMSJ9.mJVX28VeuZisR5RqFzd02A489HSz-NTE3OWDBTbb6cB0hqltHrjNRKzt0W4fsBTzcKT5tEURD-5UAEWMbkx5WWwJ-Q4_tTZ5gmBGidcVdGqtAWVkapIUFCxkIYZ1vYW9Y0gOAAI8wDFX2u5V59psYBTxPVcVCCrCfLHSuyUdxrBe-F0-tQhczDntnebPlAkDV9kic7gk7y6oe6ezFnfmAM-6R5pwQ8ENhHkJuCWfec0.IsPGy8-i1xPcXOMcYHA6LILW2PEISeow3oEeaUU30FQ&dib_tag=se&keywords=semences&qid=1779111515&s=books&sprefix=semences%2Cstripbooks%2C148&sr=1-4",
        badge: "Affilié Amazon",
        affilie: true,
      },
      {
        nom: "\"Réussir son potager bio en partant de zéro\"",
        desc: "Comprendre les principes de permaculture appliqués au potager pour créer un jardin résilient et productif.",
        lien: "https://www.amazon.fr/R%C3%A9ussir-son-potager-partant-z%C3%A9ro/dp/B08S311KVR/ref=sr_1_13_sspa?__mk_fr_FR=%C3%85M%C3%85%C5%BD%C3%95%C3%91&crid=3R3YLEB8HTQ9G&dib=eyJ2IjoiMSJ9.MhrxwpHZqhcKaFrAmiX_kBC72Im5rvt5OjGxJRZQx3mTmUYaAnD-Q2R7Kvf6_oNwD1l-IssrXTGPrjprBxwICxdm9BIyMDl9T19f86wfoRUc8Ad4I-d_rKs0-pWavwOXn8mx-oYjGaEzYA2_bB5x_ughNIgzKhzrNJK4TBJWtuN1zyBxAh--g1Rtj2XwVcsC2RAJU85HSNBRKzFmeshStMzCdxzL9Zvbz5oG4eg5fjw.trgYF-QgtIzfsFJPSSdWKCQBckpe9qTSAsGiCfJ0wL8&dib_tag=se&keywords=le+potager&qid=1779111884&s=books&sprefix=le+potager%2Cstripbooks%2C144&sr=1-13-spons&aref=FxIj8KXadX&sp_csd=d2lkZ2V0TmFtZT1zcF9tdGY&psc=1",
        badge: "Affilié Amazon",
        affilie: true,
      },
    ],
  },
