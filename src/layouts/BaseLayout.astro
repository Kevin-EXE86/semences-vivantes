---
// BaseLayout.astro
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  titre: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
}

const {
  titre,
  description = 'Semences Vivantes — Blog dédié aux semences anciennes, à la biodiversité potagère et au jardinage biologique.',
  image = '/images/og-default.jpg',
  type = 'website',
} = Astro.props;

const urlCanonique = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />

  <!-- Open Graph / SEO -->
  <meta property="og:type"        content={type} />
  <meta property="og:url"         content={urlCanonique} />
  <meta property="og:title"       content={`${titre} | Semences Vivantes`} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={image} />
  <meta property="og:locale"      content="fr_FR" />

  <link rel="canonical" href={urlCanonique} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <title>{titre} | Semences Vivantes</title>
</head>
<body>
  <Header />
  <main id="contenu-principal">
    <slot />
  </main>
  <Footer />
</body>
</html>
