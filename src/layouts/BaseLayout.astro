---
// BaseLayout.astro
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  titre: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  datePublication?: string;
  categorie?: string;
  tempsLecture?: number;
  breadcrumbs?: { label: string; href: string }[];
}

const {
  titre,
  description = 'Semences Vivantes — Blog dédié aux semences anciennes, à la biodiversité potagère et au jardinage biologique.',
  image = '/images/og-default.jpg',
  type = 'website',
  datePublication,
  categorie,
  tempsLecture,
  breadcrumbs,
} = Astro.props;

const urlCanonique = new URL(Astro.url.pathname, Astro.site);
const siteName = 'Semences Vivantes';
const titreComplet = `${titre} | ${siteName}`;

// JSON-LD structuré pour Google
const jsonLd = type === 'article' ? {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: titre,
  description,
  image: new URL(image, Astro.site).href,
  datePublished: datePublication,
  author: { '@type': 'Organization', name: siteName },
  publisher: {
    '@type': 'Organization',
    name: siteName,
    logo: { '@type': 'ImageObject', url: new URL('/favicon.svg', Astro.site).href }
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': urlCanonique.href },
} : {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  url: Astro.site,
  description,
  potentialAction: {
    '@type': 'SearchAction',
    target: `${Astro.site}blog?q={search_term_string}`,
    'query-input': 'required name=search_term_string'
  }
};

// JSON-LD breadcrumbs
const breadcrumbLd = breadcrumbs ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: Astro.site },
    ...breadcrumbs.map((b, i) => ({
      '@type': 'ListItem',
      position: i + 2,
      name: b.label,
      item: new URL(b.href, Astro.site).href,
    }))
  ]
} : null;
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <meta name="theme-color" content="#2d4a2d" />

  <!-- Open Graph -->
  <meta property="og:type"        content={type} />
  <meta property="og:url"         content={urlCanonique} />
  <meta property="og:title"       content={titreComplet} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={new URL(image, Astro.site)} />
  <meta property="og:locale"      content="fr_FR" />
  <meta property="og:site_name"   content={siteName} />
  {datePublication && <meta property="article:published_time" content={datePublication} />}
  {categorie && <meta property="article:section" content={categorie} />}

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={titreComplet} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={new URL(image, Astro.site)} />

  <!-- Temps de lecture (indicatif) -->
  {tempsLecture && <meta name="twitter:label1" content="Temps de lecture" />}
  {tempsLecture && <meta name="twitter:data1"  content={`${tempsLecture} minutes`} />}

  <link rel="canonical" href={urlCanonique} />
  <link rel="sitemap"   href="/sitemap-index.xml" />
  <link rel="icon"      type="image/svg+xml" href="/favicon.svg" />

  <!-- JSON-LD structuré -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  {breadcrumbLd && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />}

  <title>{titreComplet}</title>
</head>
<body>
  <a href="#contenu-principal" class="skip-link">Aller au contenu</a>
  <Header />
  <main id="contenu-principal">
    {breadcrumbs && (
      <nav class="breadcrumb-bar" aria-label="Fil d'Ariane">
        <div class="container breadcrumb-inner">
          <a href="/">Accueil</a>
          {breadcrumbs.map((b, i) => (
            <>
              <span aria-hidden="true">›</span>
              {i === breadcrumbs.length - 1
                ? <span aria-current="page">{b.label}</span>
                : <a href={b.href}>{b.label}</a>
              }
            </>
          ))}
        </div>
      </nav>
    )}
    <slot />
  </main>
  <Footer />
</body>
</html>

<style is:global>
.skip-link {
  position: absolute;
  top: -100%;
  left: 1rem;
  background: var(--vert-profond);
  color: var(--blanc);
  padding: 0.5rem 1rem;
  border-radius: 0 0 var(--radius) var(--radius);
  font-family: var(--font-ui);
  font-size: 0.85rem;
  z-index: 9999;
  text-decoration: none;
}
.skip-link:focus { top: 0; }

.breadcrumb-bar {
  background: var(--sable);
  border-bottom: 1px solid var(--gris-clair);
  padding: 0.6rem 0;
}
.breadcrumb-inner {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--font-ui);
  font-size: 0.78rem;
  color: var(--gris-chaud);
  flex-wrap: wrap;
}
.breadcrumb-inner a {
  color: var(--vert-mousse);
  text-decoration: none;
}
.breadcrumb-inner a:hover { text-decoration: underline; }
.breadcrumb-inner span[aria-current] { color: var(--texte); font-weight: 500; }
</style>
